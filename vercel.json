{
  "version": 2,
  "routes": [
    { "src": "/blog/([^/]+)\\.sig\\.json$", "dest": "/blogs/$1.sig.json" },
    { "src": "/\\.well-known/(.*)", "dest": "/.well-known/$1" },
    { "handle": "filesystem" },
    { "src": "/blog", "dest": "/api/blog.js" },
    { "src": "/blog/(.*)", "dest": "/api/blog/[slug].js?slug=$1" },
    { "src": "/styles/(.*)", "dest": "/styles/$1" },
    { "src": "/", "dest": "/api/index.js" }
  ]
}
