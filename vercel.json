{
  "version": 2,
  "routes": [
    { "src": "/blog/([^/]+)\\.sig\\.json", "dest": "/public/blogs/$1.sig.json" },
    { "src": "/blog", "dest": "/api/blog.js" },
    { "src": "/blog/(.*)", "dest": "/api/blog/[slug].js?slug=$1" },
    { "src": "/\\.well-known/(.*)", "dest": "/public/.well-known/$1" },
    { "src": "/", "dest": "/api/index.js" },
    { "src": "/styles/(.*)", "dest": "/public/styles/$1" }
  ]
}
